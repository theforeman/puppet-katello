### File managed with puppet ###
## Module: puppet-katello

:katello:
  :rest_client_timeout: <%= @rest_client_timeout %>

  :candlepin:
    :url: <%= @candlepin_url %>
    :oauth_key: "<%= @candlepin_oauth_key %>"
    :oauth_secret: "<%= @candlepin_oauth_secret %>"
    :ca_cert_file: <%= @candlepin_ca_cert %>
